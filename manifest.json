{
  "manifest_version": 3,
  "name": "Chat DOM Trainer",
  "version": "1.0",
  "description": "Обучаемое расширение для авто-ввода и отправки в чатах",
  "permissions": ["activeTab", "scripting", "storage", "windows"],
  "action": {
    "default_icon": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}